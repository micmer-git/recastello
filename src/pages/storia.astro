---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STORIA_MILESTONES, SITE } from '../data/site.js';
const base = '/recastello';
---

<BaseLayout
  title="Storia — La Recastello"
  description="La storia della ASD La Recastello dal 1952 ad oggi. Settant'anni di corsa in montagna a Gazzaniga, Valle Seriana."
>

  <!-- Hero -->
  <section class="relative py-32 md:py-40 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/90 to-brand-green/20"></div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F2EFE9"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-green text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Dal 1952</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        La Nostra Storia
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        Piu di settant'anni di passione per la montagna. Dalle prime gare provinciali ai campionati del mondo.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-3xl mx-auto">
      <div class="prose-custom">
        <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal">
          La Recastello nasce nel <strong>1952</strong> a <strong>Gazzaniga</strong>, nel cuore della Valle Seriana.
          Un gruppo di appassionati di montagna — minatori, operai, artigiani — decide di gareggiare con i colori del proprio paese,
          portando il nome della cima che domina la valle: il <strong>Pizzo Recastello</strong>, 2886 metri di roccia e ghiaccio tra le Orobie.
        </p>
        <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal reveal-delay-1">
          Da allora la maglia verde ha attraversato ogni epoca della corsa in montagna italiana.
          Dai sentieri polverosi degli anni Sessanta ai circuiti internazionali di oggi, la societa ha formato
          centinaia di atleti nel vivaio giovanile e conquistato oltre <strong>trenta titoli italiani</strong> tra individuali, staffette e campionati di societa.
        </p>
        <p class="text-lg text-brand-dark/80 leading-relaxed reveal reveal-delay-2">
          Oggi la Recastello e una delle realta piu vincenti della corsa in montagna nazionale, con atleti
          in <strong>maglia azzurra</strong> ai campionati europei e mondiali. Ma resta fedele alle sue radici:
          la sede e sempre a Gazzaniga, i sentieri di allenamento sono gli stessi di settant'anni fa,
          e la festa della domenica sportiva continua a riunire generazioni di corridori.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline milestones -->
  <section class="py-16 md:py-24 px-5 bg-brand-dark text-white" id="tappe">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-center mb-16 reveal">Le Tappe Fondamentali</h2>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-white/10" aria-hidden="true"></div>

        {STORIA_MILESTONES.map((m, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div class={`relative mb-12 md:mb-16 md:flex ${isLeft ? 'md:flex-row' : 'md:flex-row-reverse'} reveal reveal-delay-${Math.min(i % 4 + 1, 4)}`}>
              {/* Dot */}
              <div class="absolute left-8 md:left-1/2 -translate-x-1/2 top-2 z-10">
                <div class="w-4 h-4 rounded-full bg-brand-green border-2 border-brand-green"></div>
              </div>

              {/* Card */}
              <div class={`ml-16 md:ml-0 md:w-[calc(50%-2rem)] ${isLeft ? 'md:pr-0 md:mr-auto' : 'md:pl-0 md:ml-auto'}`}>
                <div class="bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition-colors">
                  <span class="font-display text-3xl font-bold text-brand-green">{m.year}</span>
                  <h3 class="font-display text-lg font-bold text-white mt-2 mb-2">{m.title}</h3>
                  <p class="text-white/60 text-sm leading-relaxed">{m.text}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Key numbers -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-brand-dark text-center mb-12 reveal">I Numeri</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { num: '1952', label: 'Anno di fondazione' },
          { num: '159', label: 'Atleti tesserati' },
          { num: '30+', label: 'Titoli italiani' },
          { num: '70+', label: 'Anni di attivita' },
        ].map((stat, i) => (
          <div class={`text-center bg-white border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] p-6 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="font-display text-3xl md:text-4xl font-bold text-brand-green block">{stat.num}</span>
            <span class="text-xs text-brand-dark/50 font-bold tracking-wider uppercase mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-5 bg-brand-cream">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-dark/60 text-sm mb-4">Vuoi conoscere i risultati sportivi?</p>
      <a href={`${base}/risultati/`} class="inline-flex items-center gap-2 px-7 py-3 bg-brand-dark text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-green hover:border-brand-green transition-all">
        Vai ai Risultati
      </a>
    </div>
  </section>

  <!-- Back link -->
  <div class="text-center py-12">
    <a href={`${base}/`} class="inline-flex items-center gap-2 text-sm font-bold text-brand-green hover:underline">
      ← Torna alla home
    </a>
  </div>

</BaseLayout>
