---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESULTS_2024, ATHLETES } from '../data/site.js';

// Group results by date (descending)
const byDate = new Map();
for (const r of RESULTS_2024) {
  if (!byDate.has(r.date)) byDate.set(r.date, []);
  byDate.get(r.date).push(r);
}
const sortedDates = [...byDate.keys()].sort((a, b) => b.localeCompare(a));

// Count podiums running total for the trophy drop animation
let podiumCount = 0;
const dateEntries = sortedDates.map(date => {
  const results = byDate.get(date);
  const hasPodium = results.some(r => r.podium);
  if (hasPodium) podiumCount++;
  return { date, results, hasPodium, podiumIndex: hasPodium ? podiumCount : 0 };
});

const base = '/recastello';

// Athlete lookup set for highlighting known roster athletes
const rosterNames = new Set(ATHLETES.map(a => a.name.toLowerCase()));
---

<BaseLayout
  title="Storia — La Recastello"
  description="La storia dei risultati della ASD La Recastello. Archivio gare, podi, e vittorie della corsa in montagna bergamasca."
>

  <!-- Hero -->
  <section class="relative py-32 md:py-40 px-5 bg-brand-dark text-white overflow-hidden" id="storia-hero">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/90 to-brand-green/20"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-green text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Archivio Risultati</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        La Nostra Storia
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        Dai campionati italiani alle gare di valle: ogni podio racconta fatica e passione sulle montagne orobiche.
      </p>
      <div class="flex justify-center gap-6 mt-8 reveal reveal-delay-3">
        <div class="text-center">
          <span class="font-display text-3xl font-bold text-brand-green">{RESULTS_2024.length}</span>
          <span class="block text-xs text-white/40 uppercase tracking-wider">Risultati</span>
        </div>
        <div class="text-center">
          <span class="font-display text-3xl font-bold text-brand-green">{RESULTS_2024.filter(r => r.podium).length}</span>
          <span class="block text-xs text-white/40 uppercase tracking-wider">Podi</span>
        </div>
        <div class="text-center">
          <span class="font-display text-3xl font-bold text-brand-green">{RESULTS_2024.filter(r => r.position === 1).length}</span>
          <span class="block text-xs text-white/40 uppercase tracking-wider">Vittorie</span>
        </div>
      </div>
    </div>

    <!-- Trophy collection zone -->
    <div class="trophy-collector fixed bottom-0 left-0 right-0 h-16 z-40 pointer-events-none" id="trophy-collector" aria-hidden="true"></div>
  </section>

  <!-- Timeline -->
  <section class="py-16 md:py-24 px-5 relative" id="timeline">
    <!-- Vertical timeline line -->
    <div class="absolute left-1/2 top-0 bottom-0 w-px bg-brand-dark/10 hidden md:block" aria-hidden="true"></div>

    <div class="max-w-4xl mx-auto">
      {dateEntries.map((entry, dateIdx) => {
        const dateObj = new Date(entry.date + 'T12:00:00');
        const dayStr = dateObj.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
        const isLeft = dateIdx % 2 === 0;

        return (
          <div
            class={`timeline-entry relative mb-12 md:mb-16 md:flex ${isLeft ? 'md:flex-row' : 'md:flex-row-reverse'}`}
            data-has-podium={entry.hasPodium ? 'true' : 'false'}
            data-podium-index={entry.podiumIndex}
          >
            {/* Timeline dot */}
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-6 z-10">
              <div class={`w-4 h-4 rounded-full border-2 ${entry.hasPodium ? 'bg-brand-green border-brand-green timeline-dot-podium' : 'bg-white border-brand-dark/30'}`}></div>
            </div>

            {/* Content card */}
            <div class={`md:w-[calc(50%-2rem)] ${isLeft ? 'md:pr-0 md:mr-auto' : 'md:pl-0 md:ml-auto'}`}>
              <div class={`timeline-card bg-white border-2 ${entry.hasPodium ? 'border-brand-green shadow-[4px_4px_0_#00A651]' : 'border-brand-dark/15 shadow-[3px_3px_0_#1A1A1A15]'} p-5 md:p-6 opacity-0 translate-y-8`}>
                {/* Date header */}
                <div class="flex items-center gap-3 mb-4">
                  {entry.hasPodium && <span class="text-xl" aria-label="Podio">🏆</span>}
                  <time class="font-display text-sm font-bold text-brand-dark/60 uppercase tracking-wider" datetime={entry.date}>
                    {dayStr}
                  </time>
                </div>

                {/* Group results by race */}
                {(() => {
                  const byRace = new Map();
                  for (const r of entry.results) {
                    if (!byRace.has(r.race)) byRace.set(r.race, []);
                    byRace.get(r.race).push(r);
                  }
                  return [...byRace.entries()].map(([race, raceResults]) => (
                    <div class="mb-4 last:mb-0">
                      <h3 class="font-display text-base font-bold text-brand-dark mb-2">{race}</h3>
                      <div class="space-y-1.5">
                        {raceResults.sort((a, b) => a.position - b.position).map(r => (
                          <div class={`flex items-center gap-2 text-sm ${r.podium ? 'font-medium' : ''}`}>
                            <span class={`flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full text-xs font-bold ${
                              r.position === 1 ? 'bg-yellow-400 text-yellow-900' :
                              r.position === 2 ? 'bg-gray-300 text-gray-700' :
                              r.position === 3 ? 'bg-amber-600 text-white' :
                              r.podium ? 'bg-brand-green/20 text-brand-green' :
                              'bg-brand-dark/5 text-brand-dark/50'
                            }`}>
                              {r.position}
                            </span>
                            <span class={`${rosterNames.has(r.athlete.toLowerCase()) ? 'text-brand-green font-bold' : 'text-brand-dark'}`}>
                              {r.athlete}
                            </span>
                            {r.note && <span class="text-brand-dark/40 text-xs ml-auto">{r.note}</span>}
                          </div>
                        ))}
                      </div>
                    </div>
                  ));
                })()}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Back link -->
  <div class="text-center pb-16">
    <a href={`${base}/`} class="inline-flex items-center gap-2 text-sm font-bold text-brand-green hover:underline">
      ← Torna alla home
    </a>
  </div>

</BaseLayout>

<style>
  /* Timeline card entrance */
  .timeline-card {
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Podium dot pulse */
  .timeline-dot-podium {
    animation: dotPulse 2s ease-in-out infinite;
  }
  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0,166,81,0.4); }
    50% { box-shadow: 0 0 0 8px rgba(0,166,81,0); }
  }

  /* Trophy drop animation — falls from card to collector at bottom */
  .trophy-drop {
    position: fixed;
    font-size: 1.8rem;
    z-index: 41;
    pointer-events: none;
    animation: trophyFall 1.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes trophyFall {
    0% {
      opacity: 0;
      transform: translateY(0) rotate(-15deg) scale(0.4);
    }
    10% {
      opacity: 1;
      transform: translateY(0) rotate(-10deg) scale(0.8);
    }
    70% {
      transform: translateY(var(--fall-distance, 400px)) rotate(8deg) scale(1.1);
    }
    82% {
      transform: translateY(calc(var(--fall-distance, 400px) - 20px)) rotate(-4deg) scale(1);
    }
    90% {
      transform: translateY(var(--fall-distance, 400px)) rotate(2deg) scale(1.05);
    }
    96% {
      transform: translateY(calc(var(--fall-distance, 400px) - 6px)) rotate(0) scale(1);
    }
    100% {
      opacity: 0.8;
      transform: translateY(var(--fall-distance, 400px)) rotate(0) scale(1);
    }
  }

  /* Stacked trophy in collector */
  .trophy-stacked {
    font-size: 1.5rem;
    transition: transform 0.3s ease;
    cursor: default;
    display: inline-block;
  }
  .trophy-stacked:hover {
    transform: translateY(-6px) scale(1.3) rotate(-5deg) !important;
  }
  @keyframes stackBounce {
    0% { transform: translateY(-12px) scale(0.6); opacity: 0; }
    60% { transform: translateY(2px) scale(1.1); opacity: 1; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  /* Timeline line progress fill */
  .timeline-progress {
    position: absolute;
    left: 50%;
    top: 0;
    width: 3px;
    margin-left: -1px;
    background: #00A651;
    transform-origin: top;
    transition: height 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .trophy-drop { animation: none; opacity: 1; }
    .timeline-dot-podium { animation: none; }
    .timeline-card { opacity: 1; transform: none; }
  }
</style>

<script>
  // Timeline card reveal on scroll
  const timelineCards = document.querySelectorAll('.timeline-card');
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        cardObserver.unobserve(entry.target);

        // Check if this entry has a podium — trigger trophy drop
        const timelineEntry = entry.target.closest('.timeline-entry');
        if (timelineEntry?.dataset.hasPodium === 'true') {
          spawnTrophy(entry.target);
        }
      }
    });
  }, { threshold: 0.15 });

  timelineCards.forEach(card => cardObserver.observe(card));

  // Trophy icons for variety
  const trophyIcons = ['🏆', '🥇', '🥈', '🥉', '⛰️', '🏅', '💪', '🔥', '⭐', '🎖️'];
  let trophyCount = 0;

  const collector = document.getElementById('trophy-collector');
  if (collector) {
    collector.style.display = 'flex';
    collector.style.alignItems = 'flex-end';
    collector.style.justifyContent = 'center';
    collector.style.gap = '2px';
    collector.style.flexWrap = 'wrap';
    collector.style.padding = '0 1rem';
  }

  function spawnTrophy(card) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      addToCollector(trophyIcons[trophyCount % trophyIcons.length]);
      trophyCount++;
      return;
    }

    const rect = card.getBoundingClientRect();
    const icon = trophyIcons[trophyCount % trophyIcons.length];
    const collectorRect = collector?.getBoundingClientRect();
    if (!collectorRect) return;

    // Start position: above the card
    const startX = rect.left + rect.width / 2 - 15;
    const startY = rect.top - 40;
    // End position: collector at bottom of viewport
    const endY = collectorRect.top - 10;

    const trophy = document.createElement('span');
    trophy.className = 'trophy-drop';
    trophy.textContent = icon;
    trophy.style.left = startX + 'px';
    trophy.style.top = startY + 'px';
    trophy.style.setProperty('--fall-distance', (endY - startY) + 'px');
    trophy.setAttribute('aria-hidden', 'true');
    document.body.appendChild(trophy);

    setTimeout(() => {
      trophy.remove();
      addToCollector(icon);
    }, 1400);

    trophyCount++;
  }

  function addToCollector(icon) {
    if (!collector) return;

    if (collector.querySelectorAll('.trophy-stacked').length === 0) {
      collector.style.background = 'linear-gradient(to top, rgba(26,26,26,0.92), rgba(26,26,26,0.4), transparent)';
    }

    const stacked = document.createElement('span');
    stacked.className = 'trophy-stacked';
    stacked.textContent = icon;
    const wobble = Math.random() * 12 - 6;
    stacked.style.transform = 'rotate(' + wobble + 'deg)';
    stacked.style.animation = 'stackBounce 0.4s cubic-bezier(0.34,1.56,0.64,1)';
    collector.appendChild(stacked);
  }

  // Progress line
  const timelineLine = document.querySelector('#timeline .absolute.left-1\\/2');
  if (timelineLine) {
    const progressEl = document.createElement('div');
    progressEl.className = 'timeline-progress';
    timelineLine.parentElement?.appendChild(progressEl);

    const updateProgress = () => {
      const timeline = document.getElementById('timeline');
      if (!timeline) return;
      const rect = timeline.getBoundingClientRect();
      const progress = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));
      progressEl.style.height = `${progress * 100}%`;
    };

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }
</script>
