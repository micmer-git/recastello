---
import BaseLayout from '../layouts/BaseLayout.astro';
import { POIETO_RACE, VIDEOS, FEATURED_EVENT, SITE } from '../data/site.js';
const base = '/recastello';
---

<BaseLayout
  title="La Corsa del Poieto — Memorial Pekèt"
  description="La gara di sola salita Gazzaniga-Monte Poieto. Percorso GPX interattivo, profilo altimetrico, video e storia del Memorial Pietro Lanfranchi Pekèt."
>

  <!-- Hero -->
  <section class="relative py-32 md:py-44 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/90 to-brand-green/20"></div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F2EFE9"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-green text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Gazzaniga — Monte Poieto</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,5rem)] font-bold leading-tight mb-4 reveal reveal-delay-1">
        La Corsa del Poieto
      </h1>
      <p class="font-cursive text-2xl md:text-3xl text-brand-green/80 mb-6 reveal reveal-delay-2">
        Memorial Pietro Lanfranchi "Peket"
      </p>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-3">
        Corsa in montagna — sola salita. La gara di casa della Recastello, dal 2003.
      </p>
    </div>
  </section>

  <!-- Key stats bar -->
  <section class="py-8 px-5 bg-brand-cream border-b-2 border-brand-dark/5">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { num: '12.4 km', label: 'Distanza' },
        { num: '920 m', label: 'Dislivello D+' },
        { num: '388 m', label: 'Partenza' },
        { num: '1360 m', label: 'Arrivo Monte Poieto' },
      ].map((stat, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 4)}`}>
          <span class="font-display text-2xl md:text-3xl font-bold text-brand-green block">{stat.num}</span>
          <span class="text-xs text-brand-dark/50 font-bold tracking-wider uppercase">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Race description -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-3xl mx-auto">
      <div class="prose-custom">
        <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal">
          {POIETO_RACE.description}
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
          {POIETO_RACE.highlights.map((h, i) => (
            <div class={`flex items-start gap-3 bg-white border-2 border-brand-dark shadow-[3px_3px_0_#1A1A1A] p-4 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <span class="text-brand-green font-bold text-lg mt-0.5">+</span>
              <span class="text-sm text-brand-dark/80 font-medium">{h}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive GPX Map -->
  <section class="py-16 md:py-24 px-5 bg-brand-dark text-white" id="percorso">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-center mb-4 reveal">Il Percorso</h2>
      <p class="text-white/50 text-sm text-center mb-10 reveal reveal-delay-1">Mappa interattiva con tracciati GPX — clicca sui percorsi per i dettagli</p>

      <!-- Route selector -->
      <div class="flex flex-wrap justify-center gap-3 mb-8 reveal reveal-delay-2">
        {POIETO_RACE.routes.map((route, i) => (
          <button
            class={`route-btn px-5 py-2.5 text-xs font-bold tracking-wider uppercase border-2 transition-all ${i === 0 ? 'bg-brand-green border-brand-green text-white' : 'bg-transparent border-white/20 text-white/60 hover:border-white/50'}`}
            data-route={i}
          >
            <span class="inline-block w-3 h-3 rounded-full mr-2" style={`background:${route.color}`}></span>
            {route.name}
          </button>
        ))}
      </div>

      <!-- Map container -->
      <div class="reveal reveal-delay-3">
        <div id="race-map" class="w-full h-[400px] md:h-[500px] border-2 border-white/10" style="z-index:1;"></div>
      </div>

      <!-- Route info cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
        {POIETO_RACE.routes.map((route, i) => (
          <div class={`route-card bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition-colors reveal reveal-delay-${Math.min(i + 1, 4)}`} data-route={i}>
            <div class="flex items-center gap-3 mb-3">
              <span class="w-4 h-4 rounded-full flex-shrink-0" style={`background:${route.color}`}></span>
              <h3 class="font-display text-lg font-bold">{route.name}</h3>
            </div>
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div>
                <span class="text-brand-green font-display text-xl font-bold block">{route.distance}</span>
                <span class="text-white/40 text-xs font-bold tracking-wider uppercase">Distanza</span>
              </div>
              <div>
                <span class="text-brand-green font-display text-xl font-bold block">{route.elevation}</span>
                <span class="text-white/40 text-xs font-bold tracking-wider uppercase">Dislivello</span>
              </div>
            </div>
            <p class="text-white/60 text-sm leading-relaxed">{route.description}</p>
            <div class="mt-3 flex items-center gap-4 text-xs text-white/40">
              <span>Partenza: {route.startAlt}m</span>
              <span>Arrivo: {route.endAlt}m</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Elevation profile -->
      <div class="mt-10 reveal">
        <h3 class="font-display text-xl font-bold text-center mb-4">Profilo Altimetrico</h3>
        <div class="bg-white/5 border border-white/10 p-4 md:p-6">
          <canvas id="elevation-profile" class="w-full" height="200"></canvas>
        </div>
      </div>

      <!-- GPX download -->
      <div class="flex flex-wrap justify-center gap-4 mt-8 reveal">
        {POIETO_RACE.routes.map((route) => (
          <a
            href={route.file}
            download
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-transparent border-2 border-white/20 text-white/70 text-xs font-bold tracking-wider uppercase hover:border-brand-green hover:text-brand-green transition-all"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Scarica GPX — {route.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Video Gallery -->
  <section class="py-16 md:py-24 px-5" id="video">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-brand-dark text-center mb-4 reveal">Video e Galleria</h2>
      <p class="text-brand-dark/50 text-sm text-center mb-12 reveal reveal-delay-1">Immagini e filmati dalle gare della Recastello sul Monte Poieto e in Valle Seriana</p>

      <!-- Featured video (large) -->
      <div class="mb-8 reveal reveal-delay-2">
        <div class="relative w-full aspect-video bg-brand-dark border-2 border-brand-dark shadow-[6px_6px_0_#1A1A1A] overflow-hidden">
          <iframe
            id="featured-video"
            src={`https://www.youtube-nocookie.com/embed/${VIDEOS[1].id}?rel=0`}
            title={VIDEOS[1].title}
            class="absolute inset-0 w-full h-full"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <div class="mt-3 flex items-center justify-between">
          <div>
            <h3 class="font-display text-lg font-bold text-brand-dark" id="featured-title">{VIDEOS[1].title}</h3>
            <p class="text-brand-dark/50 text-sm" id="featured-desc">{VIDEOS[1].description}</p>
          </div>
          <span class="text-brand-green font-display text-xl font-bold" id="featured-year">{VIDEOS[1].year}</span>
        </div>
      </div>

      <!-- Video grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {VIDEOS.map((video, i) => (
          <button
            class={`video-thumb group text-left reveal reveal-delay-${Math.min(i + 1, 4)}`}
            data-video-id={video.id}
            data-video-title={video.title}
            data-video-desc={video.description}
            data-video-year={video.year}
          >
            <div class="relative aspect-video bg-brand-dark border-2 border-brand-dark overflow-hidden mb-2">
              <img
                src={`https://img.youtube.com/vi/${video.id}/mqdefault.jpg`}
                alt={video.title}
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-brand-green/90 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><polygon points="8,5 20,12 8,19"/></svg>
                </div>
              </div>
            </div>
            <span class="text-xs font-bold text-brand-dark/70 group-hover:text-brand-green transition-colors line-clamp-2">{video.title}</span>
            <span class="text-[0.65rem] text-brand-dark/40">{video.year}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Next edition CTA -->
  <section class="py-16 px-5 bg-brand-cream">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-green text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Prossima Edizione</p>
      <h2 class="font-display text-3xl font-bold text-brand-dark mb-4 reveal reveal-delay-1">{FEATURED_EVENT.date}</h2>
      <p class="text-brand-dark/60 text-sm mb-6 max-w-lg mx-auto reveal reveal-delay-2">
        {FEATURED_EVENT.subtitle}. {FEATURED_EVENT.categories}.
      </p>
      <div class="flex flex-wrap justify-center gap-4 reveal reveal-delay-3">
        <a href={`${base}/`} class="inline-flex items-center gap-2 px-7 py-3 bg-brand-dark text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-green hover:border-brand-green transition-all">
          Info e Iscrizioni
        </a>
        <a href={`${base}/storia/`} class="inline-flex items-center gap-2 px-7 py-3 bg-transparent text-brand-dark font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-dark hover:text-white transition-all">
          La Nostra Storia
        </a>
      </div>
    </div>
  </section>

  <!-- Back link -->
  <div class="text-center py-12">
    <a href={`${base}/`} class="inline-flex items-center gap-2 text-sm font-bold text-brand-green hover:underline">
      &larr; Torna alla home
    </a>
  </div>

  <!-- Leaflet CSS/JS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" is:inline />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>

  <script define:vars={{ routes: POIETO_RACE.routes, mapCenter: POIETO_RACE.mapCenter, mapZoom: POIETO_RACE.mapZoom }}>
    document.addEventListener('DOMContentLoaded', async () => {
      // ── Map ──
      const map = L.map('race-map', {
        scrollWheelZoom: false,
        attributionControl: true,
      }).setView(mapCenter, mapZoom);

      L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
        maxZoom: 17,
        attribution: '&copy; OpenTopoMap',
      }).addTo(map);

      const layers = [];
      const allPoints = [];

      // Parse GPX XML and add to map
      async function loadGPX(route, index) {
        const response = await fetch(route.file);
        const text = await response.text();
        const parser = new DOMParser();
        const xml = parser.parseFromString(text, 'text/xml');
        const trkpts = xml.querySelectorAll('trkpt');

        const coords = [];
        const elevations = [];
        trkpts.forEach(pt => {
          const lat = parseFloat(pt.getAttribute('lat'));
          const lon = parseFloat(pt.getAttribute('lon'));
          const ele = parseFloat(pt.querySelector('ele')?.textContent || '0');
          coords.push([lat, lon]);
          elevations.push(ele);
          allPoints.push([lat, lon]);
        });

        const polyline = L.polyline(coords, {
          color: route.color,
          weight: 4,
          opacity: 0.9,
        }).addTo(map);

        // Start marker
        if (coords.length > 0) {
          L.circleMarker(coords[0], {
            radius: 8,
            fillColor: route.color,
            fillOpacity: 1,
            color: '#fff',
            weight: 2,
          }).addTo(map).bindPopup(`<strong>Partenza</strong><br/>${route.name}<br/>${elevations[0].toFixed(0)}m`);

          // End marker
          L.circleMarker(coords[coords.length - 1], {
            radius: 8,
            fillColor: '#ff4444',
            fillOpacity: 1,
            color: '#fff',
            weight: 2,
          }).addTo(map).bindPopup(`<strong>Arrivo</strong><br/>${route.name}<br/>${elevations[elevations.length - 1].toFixed(0)}m`);
        }

        layers.push({ polyline, coords, elevations, route });
        return { coords, elevations };
      }

      // Load all routes
      const loaded = [];
      for (let i = 0; i < routes.length; i++) {
        loaded.push(await loadGPX(routes[i], i));
      }

      // Fit map to all tracks
      if (allPoints.length > 0) {
        map.fitBounds(L.latLngBounds(allPoints), { padding: [30, 30] });
      }

      // ── Elevation profile ──
      function drawProfile(elevations, color) {
        const canvas = document.getElementById('elevation-profile');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();

        canvas.width = rect.width * dpr;
        canvas.height = 200 * dpr;
        ctx.scale(dpr, dpr);

        const w = rect.width;
        const h = 200;
        const padding = { top: 20, bottom: 30, left: 50, right: 20 };
        const plotW = w - padding.left - padding.right;
        const plotH = h - padding.top - padding.bottom;

        const minEle = Math.min(...elevations) - 20;
        const maxEle = Math.max(...elevations) + 20;

        ctx.clearRect(0, 0, w, h);

        // Grid lines
        ctx.strokeStyle = 'rgba(255,255,255,0.08)';
        ctx.lineWidth = 1;
        for (let i = 0; i <= 4; i++) {
          const y = padding.top + (plotH / 4) * i;
          ctx.beginPath();
          ctx.moveTo(padding.left, y);
          ctx.lineTo(w - padding.right, y);
          ctx.stroke();

          // Labels
          const ele = maxEle - ((maxEle - minEle) / 4) * i;
          ctx.fillStyle = 'rgba(255,255,255,0.4)';
          ctx.font = '11px Inter, sans-serif';
          ctx.textAlign = 'right';
          ctx.fillText(ele.toFixed(0) + 'm', padding.left - 8, y + 4);
        }

        // Elevation fill
        ctx.beginPath();
        ctx.moveTo(padding.left, padding.top + plotH);
        for (let i = 0; i < elevations.length; i++) {
          const x = padding.left + (i / (elevations.length - 1)) * plotW;
          const y = padding.top + plotH - ((elevations[i] - minEle) / (maxEle - minEle)) * plotH;
          ctx.lineTo(x, y);
        }
        ctx.lineTo(padding.left + plotW, padding.top + plotH);
        ctx.closePath();

        const grad = ctx.createLinearGradient(0, padding.top, 0, h);
        grad.addColorStop(0, color === '#00A651' ? 'rgba(0,166,81,0.35)' : 'rgba(26,26,26,0.35)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.fill();

        // Elevation line
        ctx.beginPath();
        for (let i = 0; i < elevations.length; i++) {
          const x = padding.left + (i / (elevations.length - 1)) * plotW;
          const y = padding.top + plotH - ((elevations[i] - minEle) / (maxEle - minEle)) * plotH;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;
        ctx.stroke();

        // Start/end labels
        ctx.fillStyle = 'rgba(255,255,255,0.5)';
        ctx.font = '10px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('Partenza', padding.left + 30, h - 6);
        ctx.fillText('Arrivo', w - padding.right - 30, h - 6);
      }

      // Draw first route by default
      if (loaded[0]) {
        drawProfile(loaded[0].elevations, routes[0].color);
      }

      // ── Route buttons ──
      document.querySelectorAll('.route-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.route);

          // Update button styles
          document.querySelectorAll('.route-btn').forEach(b => {
            b.classList.remove('bg-brand-green', 'border-brand-green', 'text-white');
            b.classList.add('bg-transparent', 'border-white/20', 'text-white/60');
          });
          btn.classList.add('bg-brand-green', 'border-brand-green', 'text-white');
          btn.classList.remove('bg-transparent', 'border-white/20', 'text-white/60');

          // Zoom to route
          if (layers[idx]) {
            map.fitBounds(L.latLngBounds(layers[idx].coords), { padding: [40, 40] });
            drawProfile(layers[idx].elevations, layers[idx].route.color);
          }
        });
      });

      // ── Video gallery ──
      document.querySelectorAll('.video-thumb').forEach(thumb => {
        thumb.addEventListener('click', () => {
          const vid = thumb.dataset.videoId;
          const iframe = document.getElementById('featured-video');
          if (iframe) iframe.src = `https://www.youtube-nocookie.com/embed/${vid}?rel=0&autoplay=1`;

          const titleEl = document.getElementById('featured-title');
          const descEl = document.getElementById('featured-desc');
          const yearEl = document.getElementById('featured-year');
          if (titleEl) titleEl.textContent = thumb.dataset.videoTitle;
          if (descEl) descEl.textContent = thumb.dataset.videoDesc;
          if (yearEl) yearEl.textContent = thumb.dataset.videoYear;

          // Scroll to featured video
          document.getElementById('featured-video')?.closest('section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    });
  </script>

</BaseLayout>
