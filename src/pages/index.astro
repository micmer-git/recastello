  <!-- ========== ARCHIVIO GARE 2018-2023 ========== -->
  <section class="py-20 md:py-28 px-5 bg-brand-dark text-white" id="archivio">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-green text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Archivio</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-4 reveal reveal-delay-1">
          Gare e Risultati 2018–2023
        </h2>
        <p class="text-white/60 max-w-xl mx-auto reveal reveal-delay-2">
          Sei stagioni di vittorie, podi e imprese sulle montagne d'Italia e d'Europa.
        </p>
      </div>

      {[2023, 2022, 2021, 2020, 2019, 2018].map((year, yi) => {
        const yearResults = RESULTS_ARCHIVE.filter(r => r.year === year);
        const yearPodiums = yearResults.filter(r => r.podium);
        const yearImages = ARCHIVE_IMAGES[year] || [];
        return (
          <div class={`mb-16 last:mb-0 reveal reveal-delay-${Math.min(yi + 1, 4)}`}>
            <div class="flex items-center gap-4 mb-6">
              <span class="font-display text-4xl md:text-5xl font-bold text-brand-green">{year}</span>
              <div class="flex-1 h-px bg-white/10"></div>
              <span class="text-xs font-bold text-white/40 tracking-wider uppercase">{yearResults.length} risultati / {yearPodiums.length} podi</span>
            </div>

            {/* Image gallery row */}
            {yearImages.length > 0 && (
              <div class="flex gap-3 mb-6 overflow-x-auto pb-2 -mx-1 px-1">
                {yearImages.map(img => (
                  <div class="flex-shrink-0 w-48 h-32 border border-white/20 overflow-hidden hover:border-brand-green/50 transition-colors">
                    <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                ))}
              </div>
            )}

            {/* Results grid */}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {yearResults.slice(0, 6).map(r => (
                <div class={`flex items-start gap-3 p-3 border ${r.podium ? 'border-brand-green/30 bg-brand-green/5' : 'border-white/5 bg-white/[0.02]'}`}>
                  <span class={`flex-shrink-0 w-7 h-7 flex items-center justify-center text-xs font-bold ${r.podium ? 'bg-brand-green text-white' : 'bg-white/10 text-white/60'}`}>
                    {r.position}
                  </span>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-white truncate">{r.athlete}</p>
                    <p class="text-xs text-white/40 truncate">{r.race}</p>
                    {r.note && <p class="text-xs text-brand-green mt-0.5">{r.note}</p>}
                  </div>
                </div>
              ))}
            </div>
            {yearResults.length > 6 && (
              <p class="text-xs text-white/30 mt-3 text-right">+ altri {yearResults.length - 6} risultati</p>
            )}
          </div>
        );
      })}

      <div class="text-center mt-12 reveal reveal-delay-4">
        <a href={`${base}/risultati/`} class="inline-flex items-center gap-2 px-7 py-3 bg-brand-green text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-green hover:bg-transparent hover:text-brand-green transition-all">
          Archivio completo risultati
        </a>
      </div>
    </div>
  </section>

  <!-- ========== BOTTOM MARQUEE ========== -->
  <div class="bg-brand-dark h-14 overflow-hidden flex items-center">
    <div class="marquee-track">
      {[...Array(8)].map(() => (
        <span class="flex-shrink-0 text-brand-green font-display text-lg font-bold tracking-wider pr-8">
          GAZZANIGA &bull; VALLE SERIANA &bull; OROBIE &bull; BERGAMO &bull;
        </span>
      ))}
    </div>
  </div>

  <script>
    // Instagram slider
    (() => {
      const slider = document.getElementById('igSlider');
      const prev = document.querySelector('.ig-prev');
      const next = document.querySelector('.ig-next');
      if (!slider || !prev || !next) return;
      let pos = 0;
      const cardW = slider.querySelector('.ig-card')?.offsetWidth || 320;
      const gap = 16;
      const step = cardW + gap;
      const maxScroll = slider.scrollWidth - slider.parentElement.offsetWidth;

      function update() {
        slider.style.transform = `translateX(-${pos}px)`;
        prev.classList.toggle('opacity-0', pos <= 0);
        prev.classList.toggle('pointer-events-none', pos <= 0);
        next.classList.toggle('opacity-0', pos >= maxScroll);
        next.classList.toggle('pointer-events-none', pos >= maxScroll);
      }
      next.addEventListener('click', () => { pos = Math.min(pos + step, maxScroll); update(); });
      prev.addEventListener('click', () => { pos = Math.max(pos - step, 0); update(); });
      update();
    })();

    // Athlete search filter
    (() => {
      const input = document.getElementById('athleteSearch');
      const grid = document.getElementById('athleteGrid');
      if (!input || !grid) return;
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        grid.querySelectorAll('.athlete-card').forEach(card => {
          const name = card.dataset.athleteName || '';
          const spec = card.dataset.athleteSpecialty || '';
          const match = !q || name.includes(q) || spec.includes(q);
          card.style.display = match ? '' : 'none';
        });
      });
    })();

    // Athlete card expand/collapse
    document.querySelectorAll('.athlete-card').forEach(card => {
      card.addEventListener('click', () => {
        const palmares = card.querySelector('.athlete-palmares');
        const chevron = card.querySelector('.athlete-chevron');
        if (!palmares) return;

        const isOpen = palmares.style.maxHeight && palmares.style.maxHeight !== '0px';
        if (isOpen) {
          palmares.style.maxHeight = '0px';
          chevron?.classList.remove('rotate-180');
        } else {
          // Close any other open cards
          document.querySelectorAll('.athlete-palmares').forEach(p => {
            p.style.maxHeight = '0px';
          });
          document.querySelectorAll('.athlete-chevron').forEach(c => {
            c.classList.remove('rotate-180');
          });
          palmares.style.maxHeight = palmares.scrollHeight + 'px';
          chevron?.classList.add('rotate-180');
        }
      });
    });
  </script>

</BaseLayout>
