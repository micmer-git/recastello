---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, BOARD, ATHLETES, SPONSORS, FEATURED_EVENT, RESULTS_2024, RESULTS_ARCHIVE, ARCHIVE_IMAGES, BADGE_TYPES, getAthleteResults } from '../data/site.js';
const base = '/recastello';
---

<BaseLayout
  title="La Recastello — Corsa in Montagna dal 1952"
  description="ASD La Recastello, societa di corsa in montagna fondata nel 1952 a Gazzaniga, Valle Seriana. Atleti, gare, storia e passione per la montagna bergamasca."
>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-brand-dark" id="hero">
    <!-- Background gradient simulating mountain landscape -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/80 to-brand-green/30"></div>
    <!-- Geometric mountain shapes -->
    <div class="absolute bottom-0 left-0 right-0 h-[40vh]">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="none" class="w-full h-full" aria-hidden="true">
        <polygon points="0,400 200,120 380,280 520,80 720,260 900,60 1100,200 1280,100 1440,220 1440,400" fill="#00A651" opacity="0.15"/>
        <polygon points="0,400 150,200 300,320 480,140 680,300 850,120 1050,280 1200,160 1440,280 1440,400" fill="#00A651" opacity="0.1"/>
        <polygon points="0,400 100,300 250,350 400,250 600,340 800,200 1000,320 1200,240 1440,340 1440,400" fill="#F2EFE9" opacity="0.05"/>
      </svg>
    </div>
    <!-- Mountain silhouette at bottom -->
    <div class="absolute bottom-0 left-0 right-0 z-10">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F2EFE9"/>
      </svg>
    </div>

    <div class="relative z-20 text-center px-5 max-w-4xl mx-auto">
      <p class="text-brand-green text-xs font-bold tracking-[0.25em] uppercase mb-6 reveal">Gazzaniga, Valle Seriana — dal 1952</p>
      <h1 class="font-cursive text-white text-[clamp(4rem,14vw,10rem)] leading-[0.85] mb-4 reveal reveal-delay-1" style="text-shadow: 0 4px 30px rgba(0,0,0,0.4);">
        La Recastello
      </h1>
      <p class="font-display text-brand-green text-[clamp(0.9rem,2.5vw,1.6rem)] tracking-[0.3em] uppercase font-bold mb-10 reveal reveal-delay-2">
        Corsa in Montagna
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3">
        <a href="#evento" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-green text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-green hover:bg-transparent hover:text-brand-green transition-all">
          Prossima gara
        </a>
        <a href="#societa" class="inline-flex items-center gap-2 px-7 py-3 bg-transparent text-white font-bold text-sm tracking-wider uppercase border-2 border-white/40 hover:border-white hover:bg-white/10 transition-all">
          La Societa
        </a>
      </div>
    </div>
  </section>

  <!-- ========== INSTAGRAM PREVIEW ========== -->
  <section class="py-12 md:py-16 px-5 bg-brand-cream" id="instagram">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-brand-dark" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <h2 class="font-display text-xl md:text-2xl font-bold text-brand-dark">@larecastello</h2>
        </div>
        <a href="https://www.instagram.com/larecastello/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2 bg-brand-dark text-white text-xs font-bold tracking-wider uppercase hover:bg-brand-green transition-colors">
          Seguici
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>

      <div class="ig-slider-container overflow-hidden relative">
        <div class="ig-slider flex gap-4 transition-transform duration-500 ease-out" id="igSlider">
          <!-- Card 1 -->
          <div class="ig-card flex-shrink-0 w-[280px] md:w-[320px] group">
            <a href="https://www.instagram.com/larecastello/" target="_blank" rel="noopener noreferrer" class="block no-underline">
              <div class="aspect-square overflow-hidden border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] group-hover:shadow-[2px_2px_0_#1A1A1A] group-hover:translate-x-[2px] group-hover:translate-y-[2px] transition-all">
                <img src={`${base}/img/example_recastello_Post.png`} alt="La Recastello post" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <p class="mt-3 text-xs text-brand-dark/60 font-medium line-clamp-2">Risultati del weekend in gara con i colori della Recastello</p>
            </a>
          </div>
          <!-- Card 2 -->
          <div class="ig-card flex-shrink-0 w-[280px] md:w-[320px] group">
            <a href="https://www.instagram.com/larecastello/" target="_blank" rel="noopener noreferrer" class="block no-underline">
              <div class="aspect-square overflow-hidden border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] group-hover:shadow-[2px_2px_0_#1A1A1A] group-hover:translate-x-[2px] group-hover:translate-y-[2px] transition-all">
                <img src={`${base}/img/exaple_recastello_post_2.png`} alt="La Recastello atleti" class="w-full h-full object-cover" loading="lazy" />
              </div>
              <p class="mt-3 text-xs text-brand-dark/60 font-medium line-clamp-2">I nostri atleti alla conquista delle vette orobiche</p>
            </a>
          </div>
          <!-- Card 3 — CTA card -->
          <div class="ig-card flex-shrink-0 w-[280px] md:w-[320px] group">
            <a href="https://www.instagram.com/larecastello/" target="_blank" rel="noopener noreferrer" class="block no-underline">
              <div class="aspect-square overflow-hidden border-2 border-brand-green bg-gradient-to-br from-brand-green/20 to-brand-green/5 flex items-center justify-center">
                <div class="text-center px-8">
                  <svg class="w-12 h-12 text-brand-green mx-auto mb-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <p class="font-display text-lg font-bold text-brand-dark mb-2">Vedi tutti i post</p>
                  <p class="text-xs text-brand-dark/50">Segui @larecastello su Instagram</p>
                </div>
              </div>
            </a>
          </div>
        </div>
        <!-- Slider arrows -->
        <button class="ig-prev absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-brand-dark text-white flex items-center justify-center hover:bg-brand-green transition-colors opacity-0 pointer-events-none" aria-label="Precedente">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="ig-next absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-brand-dark text-white flex items-center justify-center hover:bg-brand-green transition-colors" aria-label="Successivo">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <div class="bg-brand-green h-14 overflow-hidden flex items-center">
    <div class="marquee-track">
      {[...Array(8)].map(() => (
        <span class="flex-shrink-0 text-white font-display text-lg font-bold tracking-wider pr-8">
          CORSA IN MONTAGNA &bull; TRAIL RUNNING &bull; SKYRACE &bull; DAL 1952 &bull;
        </span>
      ))}
    </div>
  </div>

  <!-- ========== FEATURED EVENT ========== -->
  <section class="py-20 md:py-28 px-5" id="evento">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-green text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Prossimo appuntamento</p>
          <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-bold text-brand-dark leading-tight mb-6 reveal reveal-delay-1">
            {FEATURED_EVENT.name}
          </h2>
          <p class="text-brand-dark/70 text-lg leading-relaxed mb-8 reveal reveal-delay-2">
            {FEATURED_EVENT.description}
          </p>
          <div class="flex flex-wrap gap-4 mb-8 reveal reveal-delay-3">
            <div class="bg-white px-5 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A]">
              <span class="block text-[0.65rem] font-bold tracking-[0.15em] uppercase text-brand-green">Data</span>
              <span class="font-display text-lg font-bold">{FEATURED_EVENT.date}</span>
            </div>
            <div class="bg-white px-5 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A]">
              <span class="block text-[0.65rem] font-bold tracking-[0.15em] uppercase text-brand-green">Distanza</span>
              <span class="font-display text-lg font-bold">{FEATURED_EVENT.distance}</span>
            </div>
            <div class="bg-white px-5 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A]">
              <span class="block text-[0.65rem] font-bold tracking-[0.15em] uppercase text-brand-green">Dislivello</span>
              <span class="font-display text-lg font-bold">{FEATURED_EVENT.elevation}</span>
            </div>
          </div>
          <a href={`${base}/poieto`} class="inline-block bg-brand-green text-white font-display text-sm font-bold tracking-wider px-6 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] hover:shadow-none hover:translate-x-1 hover:translate-y-1 transition-all mb-4 reveal reveal-delay-4">Scopri il percorso →</a>
          <p class="text-sm text-brand-dark/50 font-medium reveal reveal-delay-4">{FEATURED_EVENT.registration}</p>
        </div>

        <!-- Event visual — Monte Poieto -->
        <div class="relative reveal reveal-delay-2">
          <div class="border-2 border-brand-dark shadow-[6px_6px_0_#1A1A1A] aspect-[4/3] overflow-hidden">
            <img src={`${base}/img/monte_poieto.png`} alt="Monte Poieto — vista aerea del rifugio e delle Orobie, arrivo della gara Gazzaniga-Monte Poieto" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-3 -right-3 bg-brand-dark text-white px-5 py-2 font-display text-sm font-bold tracking-wider">
            Monte Poieto — 1360m
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BOARD OF DIRECTORS ========== -->
  <section class="py-20 md:py-28 px-5 bg-brand-dark text-white" id="societa">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-green text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">La Societa</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-4 reveal reveal-delay-1">
          Consiglio Direttivo
        </h2>
        <p class="text-white/60 max-w-xl mx-auto reveal reveal-delay-2">
          Settant'anni di passione per la corsa in montagna, una tradizione che si rinnova di generazione in generazione nella Valle Seriana.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {BOARD.map((member, i) => (
          <div class={`bg-white/5 border border-white/10 p-5 text-center hover:bg-white/10 transition-colors reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="w-14 h-14 bg-brand-green/20 rounded-full flex items-center justify-center mx-auto mb-3">
              <span class="font-display text-brand-green font-bold text-lg">{member.name.charAt(0)}</span>
            </div>
            <h3 class="font-bold text-sm text-white mb-1">{member.name}</h3>
            <p class="text-brand-green text-[0.7rem] font-bold tracking-wider uppercase">{member.role}</p>
          </div>
        ))}
      </div>

      <!-- Timeline -->
      <div class="mt-20 max-w-3xl mx-auto">
        <h3 class="font-display text-xl font-bold text-brand-green mb-8 text-center reveal">Dalla valle alle vette, dal 1952</h3>
        <div class="grid md:grid-cols-3 gap-8 text-center">
          <div class="reveal reveal-delay-1">
            <span class="font-display text-4xl font-bold text-brand-green">1952</span>
            <p class="text-white/60 text-sm mt-2">Fondazione a Gazzaniga. Un gruppo di appassionati della montagna decide di gareggiare.</p>
          </div>
          <div class="reveal reveal-delay-2">
            <span class="font-display text-4xl font-bold text-brand-green">70+</span>
            <p class="text-white/60 text-sm mt-2">Anni di attivita ininterrotta, con centinaia di atleti formati nel vivaio giovanile.</p>
          </div>
          <div class="reveal reveal-delay-3">
            <span class="font-display text-4xl font-bold text-brand-green">30+</span>
            <p class="text-white/60 text-sm mt-2">Titoli italiani conquistati tra individuali, staffette e campionati di societa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ATHLETES ========== -->
  <section class="py-20 md:py-28 px-5" id="atleti">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-brand-green text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Il Gruppo</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          I Nostri Atleti
        </h2>
        <p class="text-brand-dark/60 max-w-xl mx-auto reveal reveal-delay-2">
          Dalle categorie giovanili alla maglia della nazionale. Talenti cresciuti sulle montagne orobiche.
        </p>
      </div>

      <!-- Search athletes -->
      <div class="max-w-md mx-auto mb-10 reveal reveal-delay-3">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-dark/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="athleteSearch" placeholder="Cerca atleta per nome, specialita..."
            class="w-full pl-11 pr-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-green focus:outline-none transition-colors" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="athleteGrid">
        {ATHLETES.map((athlete, i) => {
          const results = getAthleteResults(athlete.name);
          const podiums = results.filter(r => r.podium);
          const badges = athlete.badges || [];
          return (
            <div
              class={`athlete-card group bg-white border-2 border-brand-dark shadow-[5px_5px_0_#1A1A1A] hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-[2px_2px_0_#1A1A1A] transition-all overflow-hidden reveal reveal-delay-${Math.min(i + 1, 4)} cursor-pointer`}
              data-athlete-id={athlete.id}
              data-athlete-name={athlete.name.toLowerCase()}
              data-athlete-specialty={athlete.specialty.toLowerCase()}
            >
              <div class="h-48 bg-gradient-to-br from-brand-green/20 to-brand-green/5 flex items-center justify-center relative">
                <span class="font-cursive text-6xl text-brand-green/30">{athlete.name.charAt(0)}</span>
                <div class="absolute top-3 right-3 bg-brand-green text-white text-[0.6rem] font-bold tracking-wider uppercase px-2 py-1">
                  {athlete.specialty}
                </div>
                {/* Badge patches — top left corner */}
                {badges.length > 0 && (
                  <div class="absolute top-3 left-3 flex flex-wrap gap-1 max-w-[60%]">
                    {badges.slice(0, 4).map(b => {
                      const bt = BADGE_TYPES[b.type];
                      return bt ? (
                        <span class={`inline-flex items-center gap-0.5 ${bt.color} text-white text-[0.55rem] font-bold px-1.5 py-0.5 leading-tight`} title={b.label}>
                          <span class="text-[0.6rem]">{bt.icon}</span>
                        </span>
                      ) : null;
                    })}
                    {badges.length > 4 && (
                      <span class="bg-brand-dark/60 text-white text-[0.55rem] font-bold px-1.5 py-0.5">+{badges.length - 4}</span>
                    )}
                  </div>
                )}
                {podiums.length > 0 && (
                  <div class="absolute bottom-3 left-3 bg-brand-dark text-white text-[0.6rem] font-bold px-2 py-1 flex items-center gap-1">
                    <span>🏆</span> {podiums.length} podi
                  </div>
                )}
              </div>
              <div class="p-5">
                <h3 class="font-display text-lg font-bold text-brand-dark mb-1 flex items-center justify-between">
                  <a href={`${base}/atleta/${athlete.id}/`} class="hover:text-brand-green transition-colors" onclick="event.stopPropagation()">
                    {athlete.name}
                  </a>
                  <svg class="w-4 h-4 text-brand-green athlete-chevron transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </h3>
                <p class="text-sm text-brand-dark/60 leading-relaxed mb-0">{athlete.palmares}</p>
              </div>
              {/* Expandable panel — badges overview + results */}
              <div class="athlete-palmares max-h-0 overflow-hidden transition-[max-height] duration-500 ease-in-out">
                <div class="px-5 pb-5 border-t border-brand-dark/10 pt-4">
                  {/* Badge patches display */}
                  {badges.length > 0 && (
                    <div class="mb-4">
                      <h4 class="text-xs font-bold tracking-[0.15em] uppercase text-brand-dark/40 mb-2">Palmares</h4>
                      <div class="flex flex-wrap gap-1.5">
                        {badges.map(b => {
                          const bt = BADGE_TYPES[b.type];
                          return bt ? (
                            <span class={`inline-flex items-center gap-1 ${bt.color} text-white text-[0.6rem] font-bold px-2 py-1 leading-tight`}>
                              <span>{bt.icon}</span>
                              <span>{b.label}</span>
                            </span>
                          ) : null;
                        })}
                      </div>
                    </div>
                  )}
                  <h4 class="text-xs font-bold tracking-[0.15em] uppercase text-brand-green mb-3">Risultati Recenti</h4>
                  {results.length > 0 ? (
                    <ul class="space-y-2">
                      {results.slice(0, 6).map(r => (
                        <li class="flex items-start gap-2 text-xs">
                          <span class={`flex-shrink-0 w-5 h-5 flex items-center justify-center rounded-full text-[0.6rem] font-bold ${r.podium ? 'bg-brand-green text-white' : 'bg-brand-dark/10 text-brand-dark'}`}>
                            {r.position}
                          </span>
                          <div>
                            <span class="font-medium text-brand-dark">{r.race}</span>
                            {r.note && <span class="text-brand-green ml-1">— {r.note}</span>}
                            <span class="block text-brand-dark/40 text-[0.6rem]">{new Date(r.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'short' })}</span>
                          </div>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p class="text-xs text-brand-dark/40 italic">Risultati in aggiornamento</p>
                  )}
                  <a href={`${base}/atleta/${athlete.id}/`} class="inline-block mt-3 text-xs font-bold text-brand-green hover:underline" onclick="event.stopPropagation()">
                    Profilo completo →
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <div class="text-center mt-10 reveal reveal-delay-4 flex flex-col sm:flex-row gap-4 justify-center">
